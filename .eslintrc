{
  "parser": "babel-eslint",
  "extends": ["airbnb"],
  "rules": {
      "react/jsx-filename-extension": "off",
      "comma-dangle": ["error", "only-multiline"],
      "space-before-function-paren": "off",
      "yoda": [2, "never"]
  },
  "import/resolver": {
    "webpack": {
      "config": "./config/webpack.config.js"
    }
  }
}
